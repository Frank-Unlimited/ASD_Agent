# Qwen API 配置（用于对话、推荐、评估）
VITE_QWEN_API_KEY=your_qwen_api_key_here
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_QWEN_MODEL=qwen-flash   # qwen-flash / qwen-plus

# DashScope 多模态服务配置（用于图片/视频分析）
VITE_DASHSCOPE_API_KEY=your_dashscope_api_key_here
VITE_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_DASHSCOPE_MODEL=qwen3.5-plus

# 阿里云语音服务配置
VITE_ALIYUN_NLS_APPKEY=your_nls_appkey_here
VITE_ALIYUN_NLS_TOKEN=your_nls_token_here

# 后端服务配置（通过 Vite 代理，使用相对路径）
VITE_MEMORY_SERVICE_URL=/api/memory
VITE_RAG_SERVICE_URL=/api/rag

# Qwen-Omni-Realtime WebSocket（通过 Vite 代理，自动适配 ws/wss）
# 前端会根据当前协议自动选择 ws:// 或 wss://
# 无需配置 URL，代理路径为 /ws/qwen

# 文件大小限制（字节）
VITE_MAX_IMAGE_SIZE=5242880    # 5MB
VITE_MAX_VIDEO_SIZE=52428800   # 50MB

# 博查AI搜索 API 配置（用于联网搜索）
# 获取方式：https://open.bocha.cn
VITE_BOCHA_API_KEY=your_bocha_api_key_here

# 内网穿透配置（可选）
# 如果使用内网穿透（如 cpolar、ngrok），请设置此项
# 例如：VITE_TUNNEL_HOST=52095bd8.r33.cpolar.top
# 留空则使用本地开发模式
VITE_TUNNEL_HOST=
